<div style="box-sizing:border-box; width:100%; max-width:700px; margin:20px auto; padding:36px; background:#ffffff; border:2px solid #1f1f1f; border-radius:18px; color:#1f1f1f; font-family:'DejaVu Sans',Arial,sans-serif;">
  <table cellpadding="0" cellspacing="0" border="0" style="width:100%; border-collapse:collapse;">
    <tr>
      <td style="vertical-align:top; padding:0 24px 20px 0;">
        <div style="font-size:14px; text-transform:uppercase; letter-spacing:.3em; color:#666666; margin-bottom:14px;">
          [[%msgiftcards_certificate_title]]
        </div>
        <div style="font-size:48px; line-height:1; font-weight:700; margin-bottom:14px;">
          [[+nominal_formatted]]
        </div>
      </td>
      <td style="width:220px; vertical-align:top; text-align:right;">
        <div style="font-size:12px; text-transform:uppercase; letter-spacing:.18em; color:#777777; margin-bottom:8px;">
          [[%msgiftcards_certificate_expires_label]]
        </div>
        <div style="font-size:22px; line-height:1.3; font-weight:700;">
          [[+expireson_formatted:notempty=`[[+expireson_formatted]]`:default=`[[%msgiftcards_certificate_no_expiration]]`]]
        </div>
      </td>
    </tr>
    <tr>
      <td colspan="2">
        <div style="font-size:18px; line-height:1.6; color:#4a4a4a; width:100%;">
          [[%msgiftcards_certificate_description]]
        </div>
      </td>
    </tr>
  </table>

  <div style="margin:16px 0 26px; border-top:1px solid #d9d9d9;"></div>

  <div style="margin-bottom:12px; font-size:12px; text-transform:uppercase; letter-spacing:.18em; color:#777777;">
    [[%msgiftcards_certificate_code_label]]
  </div>
  <div style="padding:18px 20px; border:2px solid #1f1f1f; border-radius:14px; font-size:34px; line-height:1.25; font-weight:700; letter-spacing:.14em; word-break:break-word; margin-bottom:28px;">
    [[+code]]
  </div>

  <div style="margin-top:26px; padding-top:18px; border-top:1px solid #d9d9d9; font-size:13px; line-height:1.7; color:#666666;">
    [[%msgiftcards_certificate_help]]
  </div>
</div>
